            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lines\": [\n    { \"item_id\": 1, \"qty\": 2 },\n    { \"item_id\": 2, \"qty\": 1 }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/orders/{{order1_id}}", "host": ["{{base_url}}"], "path": ["orders", "{{order1_id}}"] }
