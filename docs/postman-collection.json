{
  "info": {
    "name": "Mini Order Loop — Part 2 + 3",
    "description": "Full API test suite: auth, draft CRUD, the 8-transition loop, guards and refusals. Run top-to-bottom with the Collection Runner against a fresh `php artisan migrate:fresh --seed`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api" },
    { "key": "rita_token", "value": "" },
    { "key": "alan_token", "value": "" },
    { "key": "order1_id", "value": "" },
    { "key": "order2_id", "value": "" },
    { "key": "order3_id", "value": "" },
    { "key": "order4_id", "value": "" },
    { "key": "item1_stock", "value": "" },
    { "key": "item2_stock", "value": "" }
  ],
  "item": [
    {
      "name": "0 — Setup",
      "item": [
        {
          "name": "Login Rita (requester)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('200, token, role=requester', () => {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(json.token).to.be.a('string');",
                  "    pm.expect(json.user.role).to.eql('requester');",
                  "});",
                  "pm.collectionVariables.set('rita_token', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"requester@demo.test\",\n  \"password\": \"password\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }
          }
        },
        {
          "name": "Login Alan (approver)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('200, token, role=approver', () => {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(json.token).to.be.a('string');",
                  "    pm.expect(json.user.role).to.eql('approver');",
                  "});",
                  "pm.collectionVariables.set('alan_token', json.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"approver@demo.test\",\n  \"password\": \"password\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }
          }
        },
        {
          "name": "Items — snapshot stock",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const items = pm.response.json().data;",
                  "pm.test('200 with catalog', () => {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(items.length).to.be.at.least(10);",
                  "});",
                  "pm.collectionVariables.set('item1_stock', items.find(i => i.sku === 'ITM-001').stock_qty);",
                  "pm.collectionVariables.set('item2_stock', items.find(i => i.sku === 'ITM-002').stock_qty);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{rita_token}}", "type": "string" }] },
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/items", "host": ["{{base_url}}"], "path": ["items"] }
          }
        }
      ]
    },
    {
      "name": "1 — Happy loop",
      "item": [
        {
          "name": "1.1 Rita creates order (2 items)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('201 draft, 2 lines, snapshot prices', () => {",
                  "    pm.response.to.have.status(201);",
                  "    pm.expect(json.order.status).to.eql('draft');",
                  "    pm.expect(json.order.lines.length).to.eql(2);",
                  "    pm.expect(Number(json.order.lines[0].unit_price)).to.eql(245);",
                  "});",
                  "pm.collectionVariables.set('order1_id', json.order.id);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{rita_token}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"remarks\": \"Office supplies\",\n  \"lines\": [\n    { \"item_id\": 1, \"qty\": 3 },\n    { \"item_id\": 2, \"qty\": 1 }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/orders", "host": ["{{base_url}}"], "path": ["orders"] }
          }
        },
        {
          "name": "1.2 Rita submits",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 submitted', () => {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(pm.response.json().order.status).to.eql('submitted');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{rita_token}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"action\": \"submit\" }",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/orders/{{order1_id}}/transitions", "host": ["{{base_url}}"], "path": ["orders", "{{order1_id}}", "transitions"] }
          }
        },
        {
          "name": "1.3 Alan rejects with reason",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('200 rejected, reason logged', () => {",
                  "    pm.response.to.have.status(200);",
                  "    pm.expect(json.order.status).to.eql('rejected');",
                  "    pm.expect(JSON.stringify(json.order.activities)).to.include('Wrong items, please revise');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{alan_token}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"action\": \"reject\", \"reason\": \"Wrong items, please revise\" }",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/orders/{{order1_id}}/transitions", "host": ["{{base_url}}"], "path": ["orders", "{{order1_id}}", "transitions"] }
          }
        },
        {
          "name": "1.4 Rita revises (lines kept)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "pm.test('200 back to draft, lines kept', () => {",
                  "    pm.response.to.have.status(200);",
